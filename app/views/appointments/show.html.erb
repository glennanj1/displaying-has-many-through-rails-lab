<h1> Appointment </h1> 

<h2><%= link_to @appointment.doctor.name, doctor_path(@appointment.doctor) %></h2> 
<h3><%= link_to @appointment.patient.name, patient_path(@appointment.patient) %></h3>
<h4><%= @appointment.appointment_datetime.strftime("%B %d, %Y") %> Time <%= @appointment.appointment_datetime.strftime("%H:%M") %></h4>